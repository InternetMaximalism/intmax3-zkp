# ─────────────────────────────────────────────────────────────────────────────
# Sepolia smoke-deploy environment template.
# Copy to `.env` (which is git-ignored) and fill in. NEVER commit a real `.env`.
#   cp .env.example .env
# Foundry auto-loads `.env` for `forge`/`cast` when run from this directory.
# ─────────────────────────────────────────────────────────────────────────────

# JSON-RPC endpoint for Sepolia. Any public/provider URL works (Alchemy, Infura,
# a public endpoint, etc.). Referenced by foundry.toml [rpc_endpoints].sepolia
# and used as `--rpc-url sepolia`.
SEPOLIA_RPC_URL=

# Optional — only needed for `forge script ... --verify` (Etherscan source verify).
ETHERSCAN_API_KEY=

# Optional — fraud-treasury address baked into the IntmaxRollup constructor.
# If unset, Deploy.s.sol defaults it to the broadcaster (msg.sender).
FRAUD_TREASURY=

# Block-producer ADDRESS authorized to call postBlockAndSubmit (posting is permissioned).
# The deploy scripts call setBlockProducer(BLOCK_PRODUCER, true); the whitelist is otherwise
# empty (fail-closed — no one can post until authorized). If unset, it defaults to the
# broadcaster (msg.sender). Set this to the address of the operational posting key when that
# key is DISTINCT from the deployer/admin key (recommended for mainnet: keep them separate).
#
# For the LOCAL anvil rehearsal, the CLI withdraw flow posts blocks with INTMAX_DEPOSIT_KEY
# (defaults to anvil's throwaway dev key 0xac09…ff80, address 0xf39F…2266). To rehearse a
# separate-key setup, pick any test key, export it as INTMAX_DEPOSIT_KEY, and set
# BLOCK_PRODUCER to its address (`cast wallet address --private-key <key>`). NEVER a real key.
BLOCK_PRODUCER=

# Set AFTER deploy: the deployed IntmaxRollup address. Read by Finalize.s.sol.
ROLLUP_ADDR=

# ─────────────────────────────────────────────────────────────────────────────
# KEY HANDLING — the private key is NEVER pasted on a CLI or stored in a file.
#
# Import your deployer key once into Foundry's encrypted keystore (interactive
# prompt; the key is typed into the prompt, not echoed, not saved as plaintext):
#
#     cast wallet import smoke-deployer --interactive
#
# Then every deploy/finalize references the keystore by name and Foundry asks
# for the keystore password at run time:
#
#     forge script script/Deploy.s.sol --rpc-url sepolia --account smoke-deployer --broadcast
#     ROLLUP_ADDR=0x... forge script script/Finalize.s.sol --rpc-url sepolia --account smoke-deployer --broadcast
#
# So NO PRIVATE_KEY variable lives in this file by design.
#
# (The LOCAL anvil rehearsal is the only place a raw `--private-key` is used,
#  and only with anvil's throwaway built-in dev key — never a real key.)
# ─────────────────────────────────────────────────────────────────────────────
